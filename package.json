  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=8192' vite",
    "dev:legacy-server": "NODE_OPTIONS='--max-old-space-size=8192' tsx server.ts",
    "build": "NODE_OPTIONS='--max-old-space-size=16384' vite build",
    "build:fast": "NODE_OPTIONS='--max-old-space-size=16384' vite build --mode production",
    "preview": "NODE_OPTIONS='--max-old-space-size=4096' vite preview",
    "clean": "rm -rf dist node_modules/.vite",
    "lint": "NODE_OPTIONS='--max-old-space-size=4096' tsc --noEmit",
    "lint:fix": "NODE_OPTIONS='--max-old-space-size=4096' eslint . --fix",
    "test": "NODE_OPTIONS='--max-old-space-size=4096' vitest",
    "deploy": "powershell -ExecutionPolicy Bypass -File deploy-simple.ps1",
    "deploy:prod": "npm run build:fast && npm run deploy",
    "analyze": "NODE_OPTIONS='--max-old-space-size=8192' npx vite-bundle-analyzer"
  },
